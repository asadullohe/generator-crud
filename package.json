{
  "name": "@asadullohe/generator-crud",
  "version": "1.1.2",
  "description": "Swagger/OpenAPI asosida CRUD module generator",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "bin": {
    "generator-crud": "bin/generator-crud.mjs"
  },
  "exports": {
    ".": "./generate-crud.mjs",
    "./template": "./build-template.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin",
    "lib",
    "_templates",
    "build-template.mjs",
    "generate-crud.mjs",
    "README.md"
  ],
  "scripts": {
    "crud": "node ./generate-crud.mjs",
    "postinstall": "node ./bin/create-default-config.mjs",
    "template": "node ./build-template.mjs"
  },
  "keywords": [
    "swagger",
    "openapi",
    "crud",
    "generator",
    "hygen"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "hygen": "^6.2.11"
  }
}
